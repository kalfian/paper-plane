# Paper Plane configuration
# Copy to .env and adjust. Do NOT commit your real .env.
#
# There is no admin-password variable: you set the admin password on first run
# via the /_app/setup page (it is stored as a bcrypt hash, never in the env).

# Public base URL of this instance (optional; used for absolute links).
APP_URL=http://localhost:8080

# Directory for persistent data (SQLite DB + uploaded site files).
DATA_DIR=./data

# TCP port the HTTP server listens on.
PORT=8080
